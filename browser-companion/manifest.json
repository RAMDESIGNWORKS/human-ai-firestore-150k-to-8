{
  "manifest_version": 3,
  "name": "EA Browser Companion",
  "description": "Send page context to your EA for guided walkthroughs.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EA Companion"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
